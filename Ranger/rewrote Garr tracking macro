"/setmorph"
{
    setglobal morph_index 0
    label morph_targets_top
    if morph_index < @text.num_words
        message setting @text.word[morph_index] at morph target morph_index
            setglobal morph_presettargets[morph_index] @text.word[morph_index]
        end if
        setglobal morph_index + 1
            pause 1
                goto morph_targets_top
    end if
}

"/settrack"
{
    setglobal track_index 0
    label track_targets_top
    if track_index < @text.num_words
        message setting @text.word[track_index] at tracking target track_index
            setglobal track_presettargets[track_index] @text.word[track_index]
        end if
        setglobal track_index + 1
            pause 1
                goto track_targets_top
    end if
}

No_index_name
{
message "* target not set"
}

mightymoprher
{
if morph_target != ""
    if morph_target == lasttarget
        "/useitem belt /return" "\r"
            set lasttarget ""
                goto end
    end if
	if @my.waist_item != "Belt of the Wild"
		"/equip beltofthewild\r"
            pause 1
	end if
	"/useitem waist /track " morph_target "\r"
        set lasttarget morph_target
else
    call No_index_name
end if
label end
}

mightytracker
{
if track_target != ""
	if @my.waist_item != "Belt of the Wild"
		"/equip beltofthewild\r"
            pause 1
	end if
	"/useitem waist /track " track_target "\r"
else
    call No_index_name
end if
}

ranger_befriend
{
if @my.waist_item != "Belt of the Wild"
    "/equip beltofthewild\r"
        pause 1
end if
"/useitem belt /befriend" "\r"
    pause 1
        "/useitem belt /control" "\r"
}

ranger_release
{
"/useitem belt /dismiss" "\r"
}

shieldstone_toggle
{
if @my.finger_item == "Shieldstone"
    goto ON
end if
label equip
    "/equip shieldstone\r"
        pause 1
label ON
if @my.finger_item == "Shieldstone"
    "/useitem shieldstone\r"
emd if
label CHECK
if @env.textLog >= "Your Shieldstone goes inert"
    pause 2
        goto equip
end if
}
